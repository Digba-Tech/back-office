# Same Supabase project the backend uses.
VITE_SUPABASE_URL=https://your-project.supabase.co
# Public anon key — safe to embed in a browser app, never the service-role key.
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL of this backend's API (admin routes live under /api/v1/admin on this).
VITE_API_BASE_URL=http://localhost:8000
